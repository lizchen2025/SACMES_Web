# Redis Configuration
REDIS_PASSWORD=sacmes_redis_secure_password_change_me

# Flask Application Configuration
SECRET_KEY=your_flask_secret_key_32_chars_long_minimum_change_in_production
AGENT_AUTH_TOKEN=your_agent_authentication_token_change_in_production

# Optional: Redis URL override (if using external Redis)
# REDIS_URL=redis://username:password@host:port/database

# Development Settings (set to 'development' for dev mode)
FLASK_ENV=production

# Logging Level
LOG_LEVEL=INFO